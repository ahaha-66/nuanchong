{
  "name": "nuanchong",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.34.4",
  "scripts": {
    "build": "turbo build",
    "dev": "dotenv -e .env -- turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:integration": "dotenv -e .env -- pnpm --filter @nuanchong/api test:integration",
    "db:generate": "dotenv -e .env -- pnpm --filter @nuanchong/api prisma:generate",
    "db:migrate": "dotenv -e .env -- pnpm --filter @nuanchong/api prisma:migrate",
    "db:seed": "dotenv -e .env -- pnpm --filter @nuanchong/api prisma:seed"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "@prisma/engines", "argon2", "esbuild", "prisma"]
  }
}
