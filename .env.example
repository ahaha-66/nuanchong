NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://nuanchong_app:nuanchong_app@localhost:5432/nuanchong
MIGRATION_DATABASE_URL=postgresql://nuanchong_migrator:nuanchong_migrator@localhost:5432/nuanchong
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=replace-with-at-least-32-characters
JWT_REFRESH_PEPPER=replace-with-at-least-32-characters
WECHAT_APP_ID=
WECHAT_APP_SECRET=
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
